# idx-trader environment template
# Copy this file to .env and fill in your values.
# NEVER commit .env to the repository — it is in .gitignore.
# In cloud routines, set these as environment variables on the routine itself,
# NOT in a .env file.

# ---------------------------------------------------------------------------
# Trading mode — NEVER default to live
# ---------------------------------------------------------------------------
TRADING_MODE=paper          # paper | live — real orders only when explicitly set to live

# ---------------------------------------------------------------------------
# Broker credentials (IDX broker)
# ---------------------------------------------------------------------------
BROKER_API_KEY=             # API key issued by your IDX broker
BROKER_API_SECRET=          # API secret / private key for request signing
BROKER_ACCOUNT_ID=          # Account ID used in all order and position requests

# ---------------------------------------------------------------------------
# Market data
# ---------------------------------------------------------------------------
IDX_DATA_SOURCE=yfinance    # yfinance | broker — source for historical price data

# ---------------------------------------------------------------------------
# Notifications
# ---------------------------------------------------------------------------
NOTIFY_CHANNEL=telegram     # telegram | email | none

# Telegram (required when NOTIFY_CHANNEL=telegram)
TELEGRAM_BOT_TOKEN=         # Token from @BotFather, format: 123456:ABCdef...
TELEGRAM_CHAT_ID=           # Your chat or group ID; get it from @userinfobot

# ---------------------------------------------------------------------------
# Locale
# ---------------------------------------------------------------------------
TIMEZONE=Asia/Jakarta       # All timestamps and market-hour logic use this zone
